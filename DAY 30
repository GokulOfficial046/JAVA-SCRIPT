<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Online Shopping</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
        }
        .products {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }
        .card {
            border: 1px solid #ccc;
            padding: 15px;
            width: 150px;
            border-radius: 10px;
        }
        button {
            margin-top: 10px;
            padding: 5px 10px;
            cursor: pointer;
        }
        #cartCount {
            font-size: 20px;
            color: green;
        }
    </style>
</head>
<body>

    <h1>🛒 Online Shopping</h1>
    <h3>Cart Count: <span id="cartCount">0</span></h3>

    <div class="products" id="productList"></div>

    <script>
        // Product Data
        const products = [
            { id: 1, name: "Shoes" },
            { id: 2, name: "Shirt" },
            { id: 3, name: "Watch" }
        ];

        let cart = [];

        // Callback Function Example
        function addToCart(product, callback) {
            cart.push(product);
            callback(cart.length);
        }

        // Update Cart Count
        function updateCartCount(count) {
            document.getElementById("cartCount").innerText = count;
        }

        // Display Products
        function displayProducts() {
            const container = document.getElementById("productList");

            products.forEach(product => {
                const div = document.createElement("div");
                div.className = "card";

                div.innerHTML = `
                    <h4>${product.name}</h4>
                    <button onclick="handleAdd(${product.id})">Add to Cart</button>
                `;

                container.appendChild(div);
            });
        }

        // Handle Add Button
        function handleAdd(id) {
            const product = products.find(p => p.id === id);
            addToCart(product, updateCartCount); // Callback used here
        }

        displayProducts();
    </script>

</body>
</html>
